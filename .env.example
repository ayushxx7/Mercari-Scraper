# Mercari-Scraper Environment Configuration

# OpenAI API Key (Required for reasoning and recommendations)
OPENAI_API_KEY=sk-your-openai-api-key

# PostgreSQL Connection String
# Format: postgresql://user:password@localhost/mercari_db
DATABASE_URL=postgresql://user:password@localhost/mercari_db

# LLM Mock Mode (1 to use mock data, 0 to use real LLM)
LLM_MOCK_MODE=0
